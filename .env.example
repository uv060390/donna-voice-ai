# ─────────────────────────────────────────────
# DentCall — Required Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# Database (PostgreSQL — use Neon.tech, Supabase, or Vercel Postgres)
DATABASE_URL="postgresql://user:password@host:5432/dentcall?sslmode=require"

# NextAuth.js
NEXTAUTH_URL="https://your-app.vercel.app"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Twilio (voice + SMS)
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_PHONE_NUMBER="+15005550006"
CLINIC_MAIN_NUMBER="+15005550006"

# Email (Resend)
RESEND_API_KEY="re_xxxxxxxxxx"
EMAIL_FROM="DentCall <noreply@dentcall.io>"
